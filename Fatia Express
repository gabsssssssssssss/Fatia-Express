<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Fatia Express</title>
<style>
body { font-family: Arial; margin:0; background:#f5f5f5; }
header { background:#ff4d4d; color:white; padding:15px; text-align:center; }
.container { padding:20px; max-width:900px; }
.item { background:white; padding:15px; margin-bottom:15px; border-radius:8px; }
.desc { font-size:14px; color:#555; margin-bottom:10px; }
button { background:#28a745; color:white; border:none; padding:8px; cursor:pointer; border-radius:5px; margin:5px; }
#cart { background:white; padding:15px; border-radius:8px; }
</style>
</head>
<body>

<header>
<h1>Fatia Express</h1>
</header>

<div class="container">

<!-- PIZZAS -->
<div class="item">
<h3>Frango com Catupiry</h3>
<p class="desc">Frango desfiado com catupiry cremoso.</p>
<button onclick="addToCart('Frango Catupiry P',35)">P - R$35</button>
<button onclick="addToCart('Frango Catupiry M',45)">M - R$45</button>
<button onclick="addToCart('Frango Catupiry G',55.90)">G - R$55,90</button>
</div>

<div class="item">
<h3>Calabresa Especial</h3>
<p class="desc">Calabresa, cebola, queijo e tempero especial.</p>
<button onclick="addToCart('Calabresa P',35)">P - R$35</button>
<button onclick="addToCart('Calabresa M',45)">M - R$45</button>
<button onclick="addToCart('Calabresa G',55.90)">G - R$55,90</button>
</div>

<div class="item">
<h3>Marguerita</h3>
<p class="desc">Queijo, tomate e manjericão fresco.</p>
<button onclick="addToCart('Marguerita P',35)">P - R$35</button>
<button onclick="addToCart('Marguerita M',45)">M - R$45</button>
<button onclick="addToCart('Marguerita G',55.90)">G - R$55,90</button>
</div>

<div class="item">
<h3>Quatro Queijos</h3>
<p class="desc">Mussarela, parmesão, gorgonzola e catupiry.</p>
<button onclick="addToCart('4 Queijos P',35)">P - R$35</button>
<button onclick="addToCart('4 Queijos M',45)">M - R$45</button>
<button onclick="addToCart('4 Queijos G',55.90)">G - R$55,90</button>
</div>

<!-- BEBIDAS -->
<div class="item">
<h3>Bebidas</h3>
<button onclick="addToCart('Coca-Cola 2L',14)">Coca 2L - R$14</button>
<button onclick="addToCart('Coca Lata',8)">Coca Lata - R$8</button>
<button onclick="addToCart('Fanta Lata',8)">Fanta - R$8</button>
<button onclick="addToCart('Sprite Lata',8)">Sprite - R$8</button>
<button onclick="addToCart('Guaraná Lata',8)">Guaraná - R$8</button>
<button onclick="addToCart('Água',5)">Água - R$5</button>
<button onclick="addToCart('Cajuína',9)">Cajuína - R$9</button>
</div>

<!-- CARRINHO -->
<div id="cart">
<h2>Carrinho</h2>
<ul id="cartItems"></ul>
<p><strong>Total: R$ <span id="total">0</span></strong></p>

<h3>Dados</h3>
<input id="nome" placeholder="Seu nome">
<input id="endereco" placeholder="Endereço">
<input id="telefone" placeholder="Telefone">

<button onclick="finalizarPedido()">Finalizar Pedido</button>
</div>

</div>

<script>
let carrinho = [];

function addToCart(nome, preco) {
  carrinho.push({nome, preco});
  atualizarCarrinho();
}

function atualizarCarrinho() {
  let lista = document.getElementById('cartItems');
  let totalEl = document.getElementById('total');
  lista.innerHTML = '';
  let total = 0;

  carrinho.forEach(item => {
    total += item.preco;
    let li = document.createElement('li');
    li.textContent = item.nome + ' - R$ ' + item.preco.toFixed(2);
    lista.appendChild(li);
  });

  totalEl.textContent = total.toFixed(2);
}

function finalizarPedido() {
  let nome = document.getElementById('nome').value;
  let endereco = document.getElementById('endereco').value;
  let telefone = document.getElementById('telefone').value;

  let mensagem = "Pedido:%0A";

  carrinho.forEach(item => {
    mensagem += item.nome + " - R$ " + item.preco.toFixed(2) + "%0A";
  });

  mensagem += "%0ATotal: R$ " + document.getElementById('total').textContent;
  mensagem += "%0ANome: " + nome;
  mensagem += "%0AEndereço: " + endereco;
  mensagem += "%0ATelefone: " + telefone;

  window.open("https://wa.me/5599999999999?text=" + mensagem);
}
</script>

</body>
</html>
